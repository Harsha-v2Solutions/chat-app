{
  "name": "ecomm-api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "npx tsx node_modules/.bin/sequelize-cli db:migrate",
    "db:migrate:undo": "npx tsx node_modules/.bin/sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "npx tsx node_modules/.bin/sequelize-cli db:migrate:undo:all",
    "db:seed": "npx tsx node_modules/.bin/sequelize-cli db:seed:all",
    "db:seed:undo": "npx tsx node_modules/.bin/sequelize-cli db:seed:undo:all",
    "db:reset": "npx tsx node_modules/.bin/sequelize-cli db:migrate:undo:all && npx tsx node_modules/.bin/sequelize-cli db:migrate && npx tsx node_modules/.bin/sequelize-cli db:seed:all",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.17.2",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/argon2": "^0.14.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.4.0",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.16.0",
    "@types/validator": "^13.15.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
